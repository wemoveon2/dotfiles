#!/bin/bash
{{ if eq .chezmoi.os "linux" -}}
sudo apt update && sudo apt upgrade
sudo apt install fzf tmux jq -y
# install zsh and ohmyzsh + p10k
if ! [[ -x "$(command -v zsh)" ]]; then
	sudo apt install zsh curl git -y
fi
if [[ "$SHELL" != "$(which zsh)" ]]; then
	sudo chsh -s "$(which zsh)"
fi
# lazygit
if ! [ -x "$(command -v lazygit)" ]; then
	LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | grep -Po '"tag_name": "v\K[^\"]*')
	curl -Lo lazygit.tar.gz "https://github.com/jesseduffield/lazygit/releases/latest/download/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
	tar -xf lazygit.tar.gz lazygit && rm lazygit.tar.gz
	sudo install lazygit /usr/local/bin
fi
# jump
if ! [ -x "$(command -v jump)" ]; then
	curl -Lo jump_0.51.0_amd64.deb https://github.com/gsamokovarov/jump/releases/download/v0.51.0/jump_0.51.0_amd64.deb && sudo dpkg -i jump_0.51.0_amd64.deb && rm jump_0.51.0_amd64.deb
fi
{{ else if eq .chezmoi.os "darwin" -}}
# Install homebrew if missing. NONINTERACTIVE=1 lets the installer run under
# chezmoi without a TTY.
if ! [ -x "/opt/homebrew/bin/brew" ] && ! [ -x "/usr/local/bin/brew" ]; then
	echo "Installing homebrew"
	NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
	echo 'eval "$(/opt/homebrew/bin/brew shellenv)"' >> ~/.zprofile
fi
# Make brew available to the rest of this script.
eval "$(/opt/homebrew/bin/brew shellenv)"
brew update
brew install age git lazygit jump jq fzf
brew install --cask flycut iterm2 rectangle
# fzf shell integration (key-bindings + completion).
"$(brew --prefix)/opt/fzf/install" --key-bindings --completion --no-update-rc --no-bash --no-fish
# zim is bootstrapped from .zshrc on first shell start; nothing to do here.
{{ end -}}

# tmux plugin manager (cross-platform).
if [ ! -d "$HOME/.tmux/plugins/tpm" ]; then
	git clone https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm"
fi
