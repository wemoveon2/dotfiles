[url "ssh://git@github.com/"]
	insteadOf = https://github.com/
[init]
	defaultBranch = main
[pull]
        rebase = true
[url "git@gitlab.nebius.dev:"]
	insteadOf = https://gitlab.nebius.dev/
[protocol]
	version = 2
[credential]
	helper = osxkeychain
[alias]
	co = checkout
	nb = "!f(){ git checkout -b \"users/$(whoami)/$1\"; };f"
	up = "!f() { git fetch origin main && git rebase origin/main; }; f"
