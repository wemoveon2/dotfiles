EXT_LIST

INSTALLED=$(code --list-extensions 2>/dev/null | sort -u)
MISSING=$(comm -23 <(printf '%s\n' "$WANTED" | sort -u) <(printf '%s\n' "$INSTALLED"))

if [ -z "$MISSING" ]; then
  echo "[vscode-extensions] all $(printf '%s\n' "$WANTED" | wc -l | tr -d ' ') extensions already installed"
  exit 0
fi

echo "[vscode-extensions] installing missing extensions:"
printf '%s\n' "$MISSING" | while read -r ext; do
  [ -z "$ext" ] && continue
  echo "  - $ext"
  code --install-extension "$ext" --force >/dev/null 2>&1 || echo "    (failed: $ext)" >&2
done

EXTRAS=$(comm -13 <(printf '%s\n' "$WANTED" | sort -u) <(printf '%s\n' "$INSTALLED"))
if [ -n "$EXTRAS" ]; then
  echo
  echo "[vscode-extensions] note: these are installed but NOT in the tracked list (not auto-removed):"
  printf '  - %s\n' $EXTRAS
fi
