#!/usr/bin/env bash
# Install missing VS Code extensions. chezmoi re-runs this script whenever the
# extension list below changes (run_onchange tracks the rendered file hash).
#
# To capture a new extension on the source machine:
#   code --list-extensions | sort > extensions.txt
#   diff with the list in this script, paste any additions.
set -euo pipefail

if ! command -v code >/dev/null 2>&1; then
  echo "[vscode-extensions] skipping — 'code' not in PATH" >&2
  exit 0
fi

read -r -d '' WANTED <<'EXT_LIST' || true
